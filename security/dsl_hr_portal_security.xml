<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_dsl_hr_attendance_request_portal_own" model="ir.rule">
            <field name="name">Portal attendance requests: own employee</field>
            <field name="model_id" ref="model_dsl_hr_attendance_request"/>
            <field name="domain_force">['|', '|', ('employee_id.user_id', '=', user.id), ('employee_id.work_contact_id', '=', user.partner_id.id), ('employee_id.dsl_manager_user_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

