<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dsl_hr_portal_user_wizard_form" model="ir.ui.view">
        <field name="name">dsl.hr.portal.user.wizard.form</field>
        <field name="model">dsl.hr.portal.user.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Employee Portal User">
                <group>
                    <field name="name"/>
                    <field name="work_email"/>
                    <field name="company_id"/>
                    <field name="department_id"/>
                    <field name="job_id"/>
                    <field name="parent_id"/>
                </group>
                <footer>
                    <button name="action_create_employee_portal_user" type="object" string="Create Portal User" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dsl_hr_portal_user_wizard" model="ir.actions.act_window">
        <field name="name">Create Portal User</field>
        <field name="res_model">dsl.hr.portal.user.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
