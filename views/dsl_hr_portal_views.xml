<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dsl_hr_attendance_request_tree" model="ir.ui.view">
        <field name="name">dsl.hr.attendance.request.tree</field>
        <field name="model">dsl.hr.attendance.request</field>
        <field name="arch" type="xml">
            <tree string="Manual Attendance Requests">
                <field name="employee_id"/>
                <field name="request_date"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="state"/>
                <field name="submitted_on"/>
            </tree>
        </field>
    </record>

    <record id="view_dsl_hr_attendance_request_form" model="ir.ui.view">
        <field name="name">dsl.hr.attendance.request.form</field>
        <field name="model">dsl.hr.attendance.request</field>
        <field name="arch" type="xml">
            <form string="Manual Attendance Request">
                <header>
                    <button name="action_mark_under_review" type="object" string="Under Review" class="btn-secondary" invisible="state not in ('submitted', 'draft')"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state == 'approved'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="state == 'rejected'"/>
                    <field name="state" widget="statusbar" statusbar_visible="submitted,under_review,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="request_date"/>
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="attendance_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="submitted_on" readonly="1"/>
                            <field name="reviewed_by" readonly="1"/>
                            <field name="reviewed_on" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="justification"/>
                        <field name="rejection_reason"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_dsl_hr_attendance_requests" model="ir.actions.act_window">
        <field name="name">Manual Attendance</field>
        <field name="res_model">dsl.hr.attendance.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_dsl_hr_leave_request_tree" model="ir.ui.view">
        <field name="name">dsl.hr.leave.request.tree</field>
        <field name="model">dsl.hr.leave.request</field>
        <field name="arch" type="xml">
            <tree string="Leave Requests">
                <field name="employee_id"/>
                <field name="leave_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="day_count"/>
                <field name="state"/>
                <field name="submitted_on"/>
            </tree>
        </field>
    </record>

    <record id="view_dsl_hr_leave_request_form" model="ir.ui.view">
        <field name="name">dsl.hr.leave.request.form</field>
        <field name="model">dsl.hr.leave.request</field>
        <field name="arch" type="xml">
            <form string="Leave Request">
                <header>
                    <button name="action_mark_under_review" type="object" string="Under Review" class="btn-secondary" invisible="state not in ('submitted', 'draft')"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state == 'approved'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="state == 'rejected'"/>
                    <field name="state" widget="statusbar" statusbar_visible="submitted,under_review,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="leave_type"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="day_count"/>
                        </group>
                        <group>
                            <field name="submitted_on" readonly="1"/>
                            <field name="reviewed_by" readonly="1"/>
                            <field name="reviewed_on" readonly="1"/>
                            <field name="attachment_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                        <field name="rejection_reason"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_dsl_hr_leave_requests" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">dsl.hr.leave.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_dsl_hr_support_ticket_tree" model="ir.ui.view">
        <field name="name">dsl.hr.support.ticket.tree</field>
        <field name="model">dsl.hr.support.ticket</field>
        <field name="arch" type="xml">
            <tree string="HR Support Tickets">
                <field name="name"/>
                <field name="subject"/>
                <field name="employee_id"/>
                <field name="category"/>
                <field name="state"/>
                <field name="submitted_on"/>
            </tree>
        </field>
    </record>

    <record id="view_dsl_hr_support_ticket_form" model="ir.ui.view">
        <field name="name">dsl.hr.support.ticket.form</field>
        <field name="model">dsl.hr.support.ticket</field>
        <field name="arch" type="xml">
            <form string="HR Support Ticket">
                <header>
                    <button name="action_mark_under_review" type="object" string="In Progress" class="btn-secondary" invisible="state != 'submitted'"/>
                    <button name="action_approve" type="object" string="Resolve" class="btn-primary" invisible="state == 'approved'"/>
                    <button name="action_reject" type="object" string="Close" class="btn-secondary" invisible="state == 'rejected'"/>
                    <field name="state" widget="statusbar" statusbar_visible="submitted,under_review,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="subject"/>
                            <field name="employee_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="submitted_on" readonly="1"/>
                            <field name="reviewed_by" readonly="1"/>
                            <field name="reviewed_on" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="rejection_reason"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_dsl_hr_support_tickets" model="ir.actions.act_window">
        <field name="name">Help Desk</field>
        <field name="res_model">dsl.hr.support.ticket</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_dsl_hr_settlement_request_tree" model="ir.ui.view">
        <field name="name">dsl.hr.settlement.request.tree</field>
        <field name="model">dsl.hr.settlement.request</field>
