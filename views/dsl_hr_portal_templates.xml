<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dsl_login_page" name="DSL HR Portal Login">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <div class="dsl-login-page">
                <section class="dsl-login-visual">
                    <div class="dsl-login-brand">
                        <span class="dsl-brand-mark">DSL</span>
                        <span class="dsl-brand-name">HR Portal</span>
                    </div>
                    <div class="dsl-login-copy">
                        <h1>Employee Portal</h1>
                        <p>Attendance, leave, support, and settlement in one focused workspace.</p>
                    </div>
                </section>
                <section class="dsl-login-panel">
                    <form class="dsl-login-form" method="post" action="/web/login">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="redirect" t-att-value="redirect"/>
                        <div class="dsl-form-header">
                            <span class="dsl-kicker">Secure access</span>
                            <h2>Sign in</h2>
                        </div>
                        <label class="dsl-field">
                            <span>Email</span>
                            <input type="text" name="login" autocomplete="username" required="required"/>
                        </label>
                        <label class="dsl-field">
                            <span>Password</span>
                            <input type="password" name="password" autocomplete="current-password" required="required"/>
                        </label>
                        <button class="dsl-primary-btn" type="submit">
                            <i class="fa fa-sign-in"/>
                            <span>Enter Portal</span>
                        </button>
                    </form>
                </section>
            </div>
        </t>
    </template>

    <template id="dsl_portal_layout" name="DSL HR Portal Layout">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <div class="dsl-portal-app" t-att-data-csrf-token="request.csrf_token()">
                <aside class="dsl-sidebar">
                    <a class="dsl-sidebar-brand" href="/dsl/dashboard">
                        <span class="dsl-brand-mark">DSL</span>
                        <span>
                            <strong>HR Portal</strong>
                            <small>Employee workspace</small>
                        </span>
                    </a>
                    <nav class="dsl-nav">
                        <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'dashboard' else ''}" href="/dsl/dashboard">
                            <i class="fa fa-tachometer"/>
                            <span>Dashboard</span>
                        </a>
                        <t t-if="has_team">
                            <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'team' else ''}" href="/dsl/team">
                                <i class="fa fa-sitemap"/>
                                <span>My Team</span>
                            </a>
                        </t>
                        <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'attendance' else ''}" href="/dsl/attendance">
                            <i class="fa fa-clock-o"/>
                            <span>Attendance</span>
                        </a>
                        <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'leave' else ''}" href="/dsl/leave">
                            <i class="fa fa-calendar"/>
                            <span>Leave</span>
                        </a>
                        <t t-if="has_team or is_hr_user">
                            <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'directory' else ''}" href="/dsl/directory">
                                <i class="fa fa-users"/>
                                <span>Directory</span>
                            </a>
                        </t>
                        <t t-if="has_employee">
                            <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'discuss' else ''}" href="/dsl/discuss">
                                <i class="fa fa-comments"/>
                                <span>Discuss</span>
                            </a>
                            <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'support' else ''}" href="/dsl/support">
                                <i class="fa fa-life-ring"/>
                                <span>Help Desk</span>
                            </a>
                            <a t-attf-class="dsl-nav-link #{'is-active' if page_name == 'settlement' else ''}" href="/dsl/settlement">
                                <i class="fa fa-sign-out"/>
                                <span>Settlement</span>
                            </a>
                        </t>
                    </nav>
                    <div class="dsl-sidebar-footer">
                        <span t-esc="employee_name"/>
                        <a href="/web/session/logout?redirect=/dsl/login">Logout</a>
                    </div>
                </aside>
                <main class="dsl-main">
                    <header class="dsl-topbar">
                        <div>
                            <span class="dsl-kicker">Today</span>
                            <h1>
                                <t t-if="page_name == 'dashboard'">Dashboard</t>
                                <t t-elif="page_name == 'attendance'">Attendance</t>
                                <t t-elif="page_name == 'leave'">Leave &amp; Holidays</t>
                                <t t-elif="page_name == 'directory'">Employee Connect</t>
                                <t t-elif="page_name == 'team'">My Team</t>
                                <t t-elif="page_name == 'discuss'">Discuss</t>
                                <t t-elif="page_name == 'support'">Help Desk</t>
                                <t t-elif="page_name == 'settlement'">Settlement</t>
                                <t t-else="">HR Portal</t>
                            </h1>
                        </div>
                        <a class="dsl-icon-btn" href="/web/session/logout?redirect=/dsl/login" title="Logout">
                            <i class="fa fa-power-off"/>
                        </a>
                    </header>
                    <div class="dsl-js-alert" role="status"/>
                    <t t-out="0"/>
                </main>
            </div>
        </t>
    </template>

    <template id="dsl_no_employee_page" name="DSL No Employee">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-empty-state">
                <i class="fa fa-id-badge"/>
                <h2>Employee profile not linked</h2>
                <p>Your portal user needs to be linked to an employee profile before this workspace can open.</p>
            </section>
        </t>
    </template>

    <template id="dsl_status_badge" name="DSL Status Badge">
        <span t-attf-class="dsl-status dsl-status-#{record.state}">
            <t t-if="record.state == 'draft'">Draft</t>
            <t t-elif="record.state == 'submitted'">Submitted</t>
            <t t-elif="record.state == 'under_review'">Under Review</t>
            <t t-elif="record.state == 'approved'">Approved</t>
            <t t-elif="record.state == 'rejected'">Rejected</t>
            <t t-else=""><span t-esc="record.state"/></t>
        </span>
    </template>

    <template id="dsl_team_request_actions" name="DSL Team Request Actions">
        <t t-if="record.state not in ('approved', 'rejected')">
            <div class="dsl-inline-actions">
                <form method="post" t-attf-action="/dsl/team/request/#{request_type}/#{record.id}/approve">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <button class="dsl-mini-btn dsl-mini-approve" type="submit">Approve</button>
                </form>
                <form method="post" t-attf-action="/dsl/team/request/#{request_type}/#{record.id}/reject">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <button class="dsl-mini-btn dsl-mini-reject" type="submit">Reject</button>
                </form>
            </div>
        </t>
    </template>


    <template id="dsl_attendance_status_panel" name="DSL Attendance Status Panel">
        <div class="dsl-panel">
            <div class="dsl-panel-title">
                <h3 t-esc="title"/>
                <span class="dsl-count-pill" t-esc="len(rows)"/>
            </div>
            <div class="dsl-list">
                <t t-foreach="rows[:6]" t-as="row">
                    <div class="dsl-list-row">
                        <i t-attf-class="fa #{icon}"/>
                        <span>
                            <strong t-esc="row['employee'].name"/>
                            <small>
                                <t t-if="row.get('department')"><span t-esc="row['department']"/></t>
                                <t t-if="row.get('company_days')"> / <span t-esc="', '.join(row['company_days'].mapped('name'))"/></t>
                                <t t-if="row.get('leave')"> / Leave until <span t-esc="row['leave'].date_to"/></t>
                            </small>
                        </span>
                    </div>
                </t>
                <t t-if="not rows">
                    <div class="dsl-muted-row">No employees in this status.</div>
                </t>
            </div>
        </div>
    </template>

    <template id="dsl_dashboard_page" name="DSL Dashboard">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-welcome-band">
                <div>
                    <span class="dsl-kicker">Welcome back</span>
                    <t t-if="employee">
                        <h2 t-esc="employee.name"/>
                        <p>
                            <t t-if="employee.job_id"><span t-esc="employee.job_id.name"/></t>
                            <t t-if="employee.department_id"> / <span t-esc="employee.department_id.name"/></t>
                        </p>
                    </t>
                    <t t-else="">
                        <h2>HR Overview</h2>
                        <p>Company-wide attendance, leave, and request monitoring.</p>
                    </t>
                </div>
                <div class="dsl-shift-chip">
                    <i class="fa fa-map-marker"/>
                    <t t-if="open_attendance">Checked in</t>
                    <t t-elif="attendance_overview"><span t-esc="overview_scope_label"/> overview</t>
                    <t t-else="">Ready</t>
                </div>
            </section>

            <section class="dsl-metric-grid">
                <a class="dsl-metric dsl-metric-teal" href="/dsl/attendance">
                    <t t-if="attendance_overview">
                        <span>Checked In Today</span>
                        <strong><span t-esc="attendance_overview['present_count']"/>/<span t-esc="attendance_overview['total_count']"/></strong>
                        <small><span t-esc="overview_scope_label"/> attendance</small>
                    </t>
                    <t t-else="">
                        <span>Attendance</span>
                        <strong>
                            <t t-if="open_attendance">Open</t>
                            <t t-else="">Clear</t>
                        </strong>
                    </t>
                    <i class="fa fa-clock-o"/>
                </a>
                <a class="dsl-metric dsl-metric-coral" href="/dsl/leave">
                    <t t-if="attendance_overview">
                        <span>Pending Leave</span>
                        <strong t-esc="len(pending_leave_requests)"/>
                        <small>Needs review</small>
                    </t>
                    <t t-else="">
                        <span>Leave Requests</span>
                        <strong t-esc="len(leave_requests)"/>
                    </t>
                    <i class="fa fa-calendar"/>
                </a>
                <a class="dsl-metric dsl-metric-gold" href="/dsl/support">
                    <span>Tickets</span>
                    <strong>
                        <t t-if="attendance_overview"><span t-esc="len(pending_support_tickets)"/></t>
                        <t t-else=""><span t-esc="len(support_tickets)"/></t>
                    </strong>
                    <i class="fa fa-life-ring"/>
                </a>
                <a class="dsl-metric dsl-metric-green" href="/dsl/settlement">
                    <span>Settlement</span>
                    <strong>
                        <t t-if="attendance_overview"><span t-esc="len(pending_settlement_requests)"/></t>
                        <t t-else=""><span t-esc="len(settlement_requests)"/></t>
                    </strong>
                    <i class="fa fa-sign-out"/>
                </a>
            </section>

            <t t-if="attendance_overview">
                <section class="dsl-status-grid">
                    <article class="dsl-status-card is-present">
                        <span>Present Now</span>
                        <strong t-esc="attendance_overview['present_count']"/>
                    </article>
                    <article class="dsl-status-card is-checked-out">
                        <span>Checked Out</span>
                        <strong t-esc="attendance_overview['checked_out_count']"/>
                    </article>
                    <article class="dsl-status-card is-leave">
                        <span>On Leave</span>
                        <strong t-esc="attendance_overview['leave_count']"/>
                    </article>
                    <article class="dsl-status-card is-holiday">
                        <span>Holiday</span>
                        <strong t-esc="attendance_overview['holiday_count']"/>
                    </article>
                    <article class="dsl-status-card is-absent">
                        <span>Absent</span>
                        <strong t-esc="attendance_overview['absent_count']"/>
                    </article>
                </section>
            </t>

            <section class="dsl-dashboard-grid dsl-dashboard-grid-single">
                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>Open Requests</h3>
                        <a t-if="employee" href="/dsl/support">New ticket</a>
                    </div>
                    <div class="dsl-list">
                        <t t-if="attendance_overview">
                            <t t-foreach="pending_leave_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-calendar"/>
                                    <span>
                                        <strong><span t-esc="record.employee_id.name"/> / <span t-esc="record.date_from"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                    </span>
                                </div>
                            </t>
                            <t t-foreach="pending_attendance_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-inbox"/>
                                    <span>
                                        <strong><span t-esc="record.employee_id.name"/> / <span t-esc="record.request_date"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                    </span>
                                </div>
                            </t>
                            <t t-if="not (pending_leave_requests or pending_attendance_requests)">
                                <div class="dsl-muted-row">No pending HR requests.</div>
                            </t>
                        </t>
                        <t t-else="">
                            <t t-foreach="leave_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-calendar"/>
                                    <span>
                                        <strong>Leave / <span t-esc="record.date_from"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                    </span>
                                </div>
                            </t>
                            <t t-foreach="attendance_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-inbox"/>
                                    <span>
                                        <strong>Attendance / <span t-esc="record.request_date"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                    </span>
                                </div>
                            </t>
                            <t t-foreach="support_tickets" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-life-ring"/>
                                    <span>
                                        <strong><span t-esc="record.name"/> / <span t-esc="record.subject"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                    </span>
                                </div>
                            </t>
                            <t t-if="not (leave_requests or attendance_requests or support_tickets)">
                                <div class="dsl-muted-row">No active requests.</div>
                            </t>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>
    <template id="dsl_attendance_page" name="DSL Attendance">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <t t-if="attendance_overview">
                <section class="dsl-action-band">
                    <div>
                        <span class="dsl-kicker"><span t-esc="overview_scope_label"/> Attendance</span>
                        <h2><span t-esc="attendance_overview['present_count']"/> checked in out of <span t-esc="attendance_overview['total_count']"/></h2>
                    </div>
                    <div class="dsl-shift-chip">
                        <i class="fa fa-calendar-check-o"/>
                        <span t-esc="attendance_overview['date']"/>
                    </div>
                </section>
                <section class="dsl-status-grid">
                    <article class="dsl-status-card is-present"><span>Present Now</span><strong t-esc="attendance_overview['present_count']"/></article>
                    <article class="dsl-status-card is-checked-out"><span>Checked Out</span><strong t-esc="attendance_overview['checked_out_count']"/></article>
                    <article class="dsl-status-card is-leave"><span>On Leave</span><strong t-esc="attendance_overview['leave_count']"/></article>
                    <article class="dsl-status-card is-holiday"><span>Holiday</span><strong t-esc="attendance_overview['holiday_count']"/></article>
                    <article class="dsl-status-card is-absent"><span>Absent</span><strong t-esc="attendance_overview['absent_count']"/></article>
                </section>

                <section class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3><span t-esc="overview_scope_label"/> Current Attendance</h3>
                    </div>
                    <table class="dsl-table dsl-current-attendance-table">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Date</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="attendance_overview['overview_rows']" t-as="row">
                                <tr>
                                    <td t-esc="row['employee'].name"/>
                                    <td t-esc="attendance_overview['date']"/>
                                    <td>
                                        <t t-if="row.get('attendance')"><span t-esc="row['attendance'].check_in"/></t>
                                        <t t-else="">-</t>
                                    </td>
                                    <td>
                                        <t t-if="row.get('attendance') and row['attendance'].check_out"><span t-esc="row['attendance'].check_out"/></t>
                                        <t t-elif="row.get('attendance')">Open</t>
                                        <t t-else="">-</t>
                                    </td>
                                    <td>
                                        <span t-attf-class="dsl-att-status dsl-att-status-#{row['status_class']}" t-esc="row['status_label']"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="not attendance_overview['overview_rows']">
                                <tr><td colspan="5">No employees found.</td></tr>
                            </t>
                        </tbody>
                    </table>
                </section>

                <section class="dsl-dashboard-grid">
                    <t t-set="title" t-value="'Present Now'"/>
                    <t t-set="rows" t-value="attendance_overview['present_rows']"/>
                    <t t-set="icon" t-value="'fa-check'"/>
                    <t t-call="dsl_hr_portal.dsl_attendance_status_panel"/>
                    <t t-set="title" t-value="'Absent'"/>
                    <t t-set="rows" t-value="attendance_overview['absent_rows']"/>
                    <t t-set="icon" t-value="'fa-exclamation'"/>
                    <t t-call="dsl_hr_portal.dsl_attendance_status_panel"/>
                    <t t-set="title" t-value="'On Leave'"/>
                    <t t-set="rows" t-value="attendance_overview['leave_rows']"/>
                    <t t-set="icon" t-value="'fa-calendar'"/>
                    <t t-call="dsl_hr_portal.dsl_attendance_status_panel"/>
                    <t t-set="title" t-value="'Holiday'"/>
                    <t t-set="rows" t-value="attendance_overview['holiday_rows']"/>
                    <t t-set="icon" t-value="'fa-star'"/>
                    <t t-call="dsl_hr_portal.dsl_attendance_status_panel"/>
                </section>
            </t>

            <t t-if="employee">
                <section class="dsl-action-band">
                    <div>
                        <span class="dsl-kicker">Live Punch</span>
                        <h2>
                            <t t-if="open_attendance">Currently checked in</t>
                            <t t-else="">Not checked in</t>
                        </h2>
                    </div>
                    <div class="dsl-button-row">
                        <button class="dsl-primary-btn" type="button" data-dsl-punch="clock_in" t-att-disabled="'disabled' if open_attendance else None">
                            <i class="fa fa-play"/>
                            <span>Check In</span>
                        </button>
                        <button class="dsl-secondary-btn" type="button" data-dsl-punch="clock_out" t-att-disabled="None if open_attendance else 'disabled'">
                            <i class="fa fa-stop"/>
                            <span>Check Out</span>
                        </button>
                    </div>
                </section>

                <section class="dsl-two-column">
                    <div class="dsl-panel">
                        <div class="dsl-panel-title">
                            <h3>Manual Attendance</h3>
                        </div>
                        <form class="dsl-form-grid" method="post" action="/dsl/attendance/manual">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <label class="dsl-field">
                                <span>Date</span>
                                <input type="date" name="request_date" required="required"/>
                            </label>
                            <label class="dsl-field">
                                <span>Check In</span>
                                <input type="time" name="check_in_time" required="required"/>
                            </label>
                            <label class="dsl-field">
                                <span>Check Out</span>
                                <input type="time" name="check_out_time" required="required"/>
                            </label>
                            <label class="dsl-field dsl-span-2">
                                <span>Justification</span>
                                <textarea name="justification" rows="4" required="required"></textarea>
                            </label>
                            <button class="dsl-primary-btn dsl-span-2" type="submit">
                                <i class="fa fa-paper-plane"/>
                                <span>Submit Request</span>
                            </button>
                        </form>
                    </div>
                    <div class="dsl-panel">
                        <div class="dsl-panel-title">
                            <h3>Recent Logs</h3>
                        </div>
                        <table class="dsl-table">
                            <thead>
                                <tr>
                                    <th>Check In</th>
                                    <th>Check Out</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="attendance_records" t-as="record">
                                    <tr>
                                        <td t-esc="record.check_in"/>
                                        <td>
                                            <t t-if="record.check_out"><span t-esc="record.check_out"/></t>
                                            <t t-else="">Open</t>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="not attendance_records">
                                    <tr><td colspan="2">No attendance entries.</td></tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </section>
            </t>

            <section class="dsl-panel">
                <div class="dsl-panel-title">
                    <h3><t t-if="attendance_overview"><span t-esc="overview_scope_label"/> Manual Requests</t><t t-else="">Manual Requests</t></h3>
                </div>
                <table class="dsl-table">
                    <thead>
                        <tr>
                            <t t-if="attendance_overview"><th>Employee</th></t>
                            <th>Date</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Status</th>
                            <t t-if="attendance_overview"><th>Action</th></t>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="request_rows" t-value="team_attendance_requests if attendance_overview else manual_requests"/>
                        <t t-foreach="request_rows" t-as="record">
                            <tr>
                                <t t-if="attendance_overview"><td t-esc="record.employee_id.name"/></t>
                                <td t-esc="record.request_date"/>
                                <td t-esc="record.check_in"/>
                                <td t-esc="record.check_out"/>
                                <td><t t-call="dsl_hr_portal.dsl_status_badge"/></td>
                                <t t-if="attendance_overview">
                                    <td>
                                        <t t-set="request_type" t-value="'attendance'"/>
                                        <t t-call="dsl_hr_portal.dsl_team_request_actions"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                        <t t-if="not request_rows">
                            <tr><td t-att-colspan="6 if attendance_overview else 4">No manual requests.</td></tr>
                        </t>
                    </tbody>
                </table>
            </section>
        </t>
    </template>
    <template id="dsl_leave_page" name="DSL Leave">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <t t-if="leave_error == 'blocked'">
                <section class="dsl-alert is-error">
                    Leave cannot be requested on company holidays or important days. Choose a working day range.
                </section>
            </t>
            <t t-elif="leave_error">
                <section class="dsl-alert is-error">
                    Leave request was not saved. Check the dates and try again.
                </section>
            </t>

            <section class="dsl-two-column">
                <t t-if="employee">
                    <div class="dsl-panel">
                        <div class="dsl-panel-title">
                            <h3>New Leave Request</h3>
                        </div>
                        <form class="dsl-form-grid" method="post" action="/dsl/leave/request" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <label class="dsl-field dsl-span-2">
                                <span>Leave Type</span>
                                <select name="leave_type" required="required">
                                    <option value="casual">Casual</option>
                                    <option value="sick">Sick</option>
                                    <option value="annual">Annual</option>
                                    <option value="unpaid">Unpaid</option>
                                    <option value="other">Other</option>
                                </select>
                            </label>
                            <label class="dsl-field">
                                <span>From</span>
                                <input type="date" name="date_from" required="required"/>
                            </label>
                            <label class="dsl-field">
                                <span>To</span>
                                <input type="date" name="date_to" required="required"/>
                            </label>
                            <label class="dsl-field dsl-span-2">
                                <span>Attachment</span>
                                <input type="file" name="attachment"/>
                            </label>
                            <label class="dsl-field dsl-span-2">
                                <span>Reason</span>
                                <textarea name="reason" rows="4" required="required"></textarea>
                            </label>
                            <button class="dsl-primary-btn dsl-span-2" type="submit">
                                <i class="fa fa-paper-plane"/>
                                <span>Submit Leave</span>
                            </button>
                        </form>
                    </div>
                </t>

                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>Company Holidays &amp; Important Days</h3>
                    </div>
                    <div class="dsl-list">
                        <t t-foreach="company_days" t-as="day">
                            <div class="dsl-list-row">
                                <i t-attf-class="fa #{'fa-star' if day.day_type == 'important' else 'fa-calendar'}"/>
                                <span>
                                    <strong t-esc="day.name"/>
                                    <small>
                                        <span t-esc="day.date_from"/>
                                        <t t-if="day.date_to != day.date_from"> to <span t-esc="day.date_to"/></t>
                                        / <span t-esc="'Important Day' if day.day_type == 'important' else 'Holiday'"/>
                                    </small>
                                </span>
                            </div>
                        </t>
                        <t t-if="not company_days">
                            <div class="dsl-muted-row">No upcoming company holidays or important days.</div>
                        </t>
                    </div>
                </div>
            </section>

            <section class="dsl-two-column">
                <t t-if="employee">
                    <div class="dsl-panel">
                        <div class="dsl-panel-title">
                            <h3>My Leave Requests</h3>
                        </div>
                        <div class="dsl-list">
                            <t t-foreach="leave_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-calendar"/>
                                    <span>
                                        <strong><span t-esc="record.date_from"/> to <span t-esc="record.date_to"/></strong>
                                        <small>
                                            <span t-esc="record.day_count"/> day(s)
                                            <t t-call="dsl_hr_portal.dsl_status_badge"/>
                                        </small>
                                    </span>
                                </div>
                            </t>
                            <t t-if="not leave_requests">
                                <div class="dsl-muted-row">No leave requests.</div>
                            </t>
                        </div>
                    </div>
                </t>

                <t t-if="team_leave_requests">
                    <div class="dsl-panel">
                        <div class="dsl-panel-title">
                            <h3><span t-esc="overview_scope_label"/> Pending Leave</h3>
                        </div>
                        <div class="dsl-list">
                            <t t-foreach="team_leave_requests" t-as="record">
                                <div class="dsl-list-row">
                                    <i class="fa fa-calendar"/>
                                    <span>
                                        <strong><span t-esc="record.employee_id.name"/> / <span t-esc="record.date_from"/> to <span t-esc="record.date_to"/></strong>
                                        <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                        <t t-set="request_type" t-value="'leave'"/>
                                        <t t-call="dsl_hr_portal.dsl_team_request_actions"/>
                                    </span>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </section>
        </t>
    </template>
    <template id="dsl_directory_page" name="DSL Directory">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-panel">
                <div class="dsl-panel-title">
                    <h3>Employee Connect</h3>
                    <form class="dsl-search" method="get" action="/dsl/directory">
                        <input type="search" name="q" t-att-value="search_query" placeholder="Search people"/>
                        <button type="submit"><i class="fa fa-search"/></button>
                    </form>
                </div>
                <div class="dsl-directory-grid">
                    <t t-foreach="directory_rows" t-as="row">
                        <article class="dsl-person-card">
                            <div class="dsl-avatar"><t t-esc="row['name'][:1]"/></div>
                            <div>
                                <h4 t-esc="row['name']"/>
                                <p t-esc="row['job_title']"/>
                                <small>
                                    <span t-esc="row['department']"/>
                                    <t t-if="row['work_email']"> / <span t-esc="row['work_email']"/></t>
                                </small>
                            </div>
                        </article>
                    </t>
                    <t t-if="not directory_rows">
                        <div class="dsl-muted-row">No employees found.</div>
                    </t>
                </div>
            </section>
        </t>
    </template>

    <template id="dsl_team_page" name="DSL Team">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-action-band">
                <div>
                    <span class="dsl-kicker">Team Hierarchy</span>
                    <h2><span t-esc="len(team_employees)"/> people under you</h2>
                </div>
                <a class="dsl-secondary-btn" href="/dsl/directory">
                    <i class="fa fa-search"/>
                    <span>Directory</span>
                </a>
            </section>

            <section class="dsl-panel">
                <div class="dsl-panel-title">
                    <h3>People Under You</h3>
                </div>
                <div class="dsl-directory-grid">
                    <t t-foreach="team_employees" t-as="member">
                        <article class="dsl-person-card">
                            <div class="dsl-avatar"><t t-esc="member.name[:1]"/></div>
                            <div>
                                <h4 t-esc="member.name"/>
                                <p>
                                    <t t-if="member.job_id"><span t-esc="member.job_id.name"/></t>
                                    <t t-else="">Employee</t>
                                </p>
                                <small>
                                    <t t-if="member.department_id"><span t-esc="member.department_id.name"/></t>
                                    <t t-if="member.work_email"> / <span t-esc="member.work_email"/></t>
                                </small>
                            </div>
                        </article>
                    </t>
                    <t t-if="not team_employees">
                        <div class="dsl-muted-row">No employees report to you in the current hierarchy.</div>
                    </t>
                </div>
            </section>
        </t>
    </template>
    <template id="dsl_discuss_page" name="DSL Discuss">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-action-band">
                <div>
                    <span class="dsl-kicker">HR conversations</span>
                    <h2>Discuss</h2>
                </div>
                <a class="dsl-primary-btn" href="/dsl/support">
                    <i class="fa fa-plus"/>
                    <span>Open Ticket</span>
                </a>
            </section>
            <section class="dsl-panel">
                <div class="dsl-panel-title">
                    <h3>Recent Threads</h3>
                </div>
                <div class="dsl-list">
                    <t t-foreach="support_tickets" t-as="record">
                        <div class="dsl-list-row">
                            <i class="fa fa-comment"/>
                            <span>
                                <strong><span t-esc="record.name"/> / <span t-esc="record.subject"/></strong>
                                <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                            </span>
                        </div>
                    </t>
                    <t t-if="not support_tickets">
                        <div class="dsl-muted-row">No threads yet.</div>
                    </t>
                </div>
            </section>
        </t>
    </template>

    <template id="dsl_support_page" name="DSL Support">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-two-column">
                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>New Ticket</h3>
                    </div>
                    <form class="dsl-form-grid" method="post" action="/dsl/support/create">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label class="dsl-field dsl-span-2">
                            <span>Subject</span>
                            <input type="text" name="subject" required="required"/>
                        </label>
                        <label class="dsl-field dsl-span-2">
                            <span>Category</span>
                            <select name="category" required="required">
                                <option value="general">General</option>
                                <option value="attendance">Attendance</option>
                                <option value="leave">Leave</option>
                                <option value="documents">Documents</option>
                                <option value="settlement">Settlement</option>
                            </select>
                        </label>
                        <label class="dsl-field dsl-span-2">
                            <span>Description</span>
                            <textarea name="description" rows="5" required="required"></textarea>
                        </label>
                        <button class="dsl-primary-btn dsl-span-2" type="submit">
                            <i class="fa fa-paper-plane"/>
                            <span>Submit Ticket</span>
                        </button>
                    </form>
                </div>
                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>Ticket History</h3>
                    </div>
                    <div class="dsl-list">
                        <t t-foreach="support_tickets" t-as="record">
                            <div class="dsl-list-row">
                                <i class="fa fa-life-ring"/>
                                <span>
                                    <strong><span t-esc="record.name"/> / <span t-esc="record.subject"/></strong>
                                    <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                </span>
                            </div>
                        </t>
                        <t t-if="not support_tickets">
                            <div class="dsl-muted-row">No tickets yet.</div>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <template id="dsl_settlement_page" name="DSL Settlement">
        <t t-call="dsl_hr_portal.dsl_portal_layout">
            <section class="dsl-two-column">
                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>Resignation Request</h3>
                    </div>
                    <form class="dsl-form-grid" method="post" action="/dsl/settlement/submit">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label class="dsl-field dsl-span-2">
                            <span>Last Working Day</span>
                            <input type="date" name="last_working_day" required="required"/>
                        </label>
                        <label class="dsl-check dsl-span-2">
                            <input type="checkbox" name="notice_acknowledged" value="1" required="required"/>
                            <span>Notice period acknowledged</span>
                        </label>
                        <label class="dsl-field dsl-span-2">
                            <span>Formal Justification</span>
                            <textarea name="reason" rows="5" required="required"></textarea>
                        </label>
                        <button class="dsl-primary-btn dsl-span-2" type="submit">
                            <i class="fa fa-paper-plane"/>
                            <span>Submit Settlement</span>
                        </button>
                    </form>
                </div>
                <div class="dsl-panel">
                    <div class="dsl-panel-title">
                        <h3>Settlement History</h3>
                    </div>
                    <div class="dsl-list">
                        <t t-foreach="settlement_requests" t-as="record">
                            <div class="dsl-list-row">
                                <i class="fa fa-sign-out"/>
                                <span>
                                    <strong>Last day: <span t-esc="record.last_working_day"/></strong>
                                    <small><t t-call="dsl_hr_portal.dsl_status_badge"/></small>
                                </span>
                            </div>
                        </t>
                        <t t-if="not settlement_requests">
                            <div class="dsl-muted-row">No settlement requests.</div>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>
</odoo>
